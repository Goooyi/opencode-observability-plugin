{
  "name": "@goooyi/opencode-observability-plugin",
  "version": "0.1.7",
  "description": "OpenCode plugin that sends session telemetry and reasoning parts to Langfuse.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "type": "module",
  "author": "Langfuse, fork maintained by Goooyi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Goooyi/opencode-observability-plugin.git"
  },
  "bugs": {
    "url": "https://github.com/Goooyi/opencode-observability-plugin/issues"
  },
  "homepage": "https://github.com/Goooyi/opencode-observability-plugin#readme",
  "keywords": [
    "langfuse",
    "opencode",
    "plugin",
    "observability",
    "opentelemetry"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@langfuse/otel": "^5.4.1",
    "@opencode-ai/plugin": "^1.15.13",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "effect": "^3.21.2"
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  }
}
